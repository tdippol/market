$(VERBOSE).SILENT:
ifeq ($(MVNGOAL),)
	MVNGOAL := clean
endif
PROJECT_VERSION := $(shell cd ../app && cat pom.xml | grep "<revision>" | cut -d '>' -f 2 | cut -d '<' -f 1)
CHANGELIST:= $(shell cd ../app && cat pom.xml | grep "<changelist>" | cut -d '>' -f 2 | cut -d '<' -f 1)
SHA1=""

#user id
UID=$(shell id -u)
current_dir = $(shell pwd)
APPS="${current_dir}/docker/apps"
# WLSDIR="${current_dir}/docker/weblogic"
LOGS="${current_dir}/docker/logs"
MAVEN_CACHE_DIR="${current_dir}/docker/maven"
# DATA_ARCHIVES=dbpromo.tar.gz muipromo.tar.gz tomcat_auth.tar.gz mui.tar.gz
DATA_ARCHIVES=sql_data.tar.gz
INIT_SCRIPT_DIR=temp_data
DATABASE="${current_dir}/docker/database"
DATA_DIRECTORY="${current_dir}/docker/${INIT_SCRIPT_DIR}"
MAVEN_ARCHIVE="${current_dir}/docker/maven.tar.gz"
OUTPUT_FILE="${current_dir}/docker/docker-compose.yml"
MVN_VERSION="3.8.1-adoptopenjdk-8"
DOCKER_COMPOSE_FILE=${current_dir}/docker/docker-compose.yaml
DOCKER_COMPOSE_TEMPLATE=${current_dir}/docker/template.yml
EAR_TARGET_DIR=${current_dir}/../app/ear/target
EAR_TARGET_FILE=${EAR_TARGET_DIR}/muipromo-${PROJECT_VERSION}${SHA1}${CHANGELIST}.ear
SRC_DIR=${current_dir}/../app
DOCUMENT_DIR="${current_dir}/docker/documents"
WEBAPPS_DIR="${current_dir}/docker/webapps"
PROFILE=tomee
DOMAINS_DIR=domains
DOMAIN=base_domain
SOURCEBASE="${current_dir}/../app"
.DEFAULT_GOAL := help

#Function to print help based on comments
HELP_FUN = \
    %help; while(<>){push@{$$help{$$2//'options'}},[$$1,$$3] \
    if/^([\w-_]+)\s*:.*\#\#(?:@(\w+))?\s(.*)$$/}; \
    print"$$_:\n", map"  $$_->[0]".(" "x(20-length($$_->[0])))."$$_->[1]\n",\
    @{$$help{$$_}},"\n" for keys %help; \

.PHONY: help all generate up clean
shell=/bin/bash

help: ##@Miscellaneous Show this help
	@echo "Usage: make [variable=value] [target] ...\n"
	@echo "Available variables \n"
	@echo "    OUTPUT_FILE: the file name to use for generating the compose file. Defaults to \"$(OUTPUT_FILE)\""
	@echo "    UID: user id to use within the compose file [defaults to (id -u)]"
	@echo "    DATABASE: the data directory to create for the database container. Defaults to \"$(DATABASE)\""
	@echo "    APPS: the apps directory to create for the application container. Defaults to \"$(APPS)\""	
	@echo "    LOGS: the logs directory to create for the application container. Defaults to \"$(LOGS)\""		
	@echo "    DATA_ARCHIVE: the name of the archive containing the databases. Defaults to \"$(DATA_ARCHIVE)\""	
	@echo "    DATA_DIRECTORY: the path to the directory containing the init files for the databases. Defaults to \"$(DATA_DIRECTORY)\""				
	@echo "    MAVEN_CACHE_DIR: location of the maven cache. Defaults to \"$(MAVEN_CACHE_DIR)\""				
	@echo "    PROJECT_VERSION: The java project version (usually read from maven pom file). Defaults to \"$(PROJECT_VERSION)\""
	@echo "    DOCKER_COMPOSE_FILE: the docker compose file name that's being generated. Defaults to \"${DOCKER_COMPOSE_FILE}\""
	@echo "    DOCKER_COMPOSE_TEMPLATE: the docker tempate file. Defaults to \"${DOCKER_COMPOSE_TEMPLATE}\""
	@echo "    EAR_TARGET_FILE: the ear file that's being generated by mvn, full path. Defaults to \"${EAR_TARGET_FILE}\""
	@echo "    SRC_DIR: the source directory of the project being compiled. Defaults to \"${SRC_DIR}\""
	@echo "    DOMAINS_DIR: wls domains directory, defaults to ${DOMAINS_DIR}"
	@echo "    DOMAIN: wls domain name, defaults to ${DOMAIN}"
	@echo "    PROFILE: the docker compose profile. Defaults to \"${PROFILE}\". Possible values are : \n\t- tomee [default]: runs tomee server\n\t- weblogic: runs weblogic server\n\t- create-domain: runs weblogic server creating a new domain"
	@echo "    SOURCEBASE: the directory where the code sits. Used to generate coverage report"
	@echo "\nTARGETS [by category]\n"
	@perl -e '$(HELP_FUN)' $(MAKEFILE_LIST)

generate: $(DATA_ARCHIVES)	##@Setup Generates the docker-compose file and the directories
	echo "Checking directories ..."
	if [ ! -d ${APPS} ] ; then \
		echo "\tcreating ${APPS}"; \
		mkdir ${APPS}; \
	fi
	if [ ! -d ${LOGS} ] ; then \
		echo "\tcreating ${LOGS}"; \
		mkdir ${LOGS}; \
	fi
	if [ ! -d ${MAVEN_CACHE_DIR} ] ; then \
		if [ -f ${MAVEN_ARCHIVE} ]; then \
			echo "\tuncompressing lib archive ${MAVEN_ARCHIVE}"; \
			tar -xzf ${MAVEN_ARCHIVE} --directory=${current_dir}/docker ;\
		else \
			echo "\tcreating empty ${MAVEN_CACHE_DIR}" ; \
			mkdir ${MAVEN_CACHE_DIR}; \
		fi; \
	fi
	if [ ! -d ${DATABASE} ] ; then \
		echo "\tcreating ${DATABASE}"; \
		mkdir ${DATABASE}; \
	fi
	if [ ! -d ${DOCUMENT_DIR} ] ; then \
		echo "\tcreating ${DOCUMENT_DIR}"; \
		mkdir ${DOCUMENT_DIR}; \
	fi
	if [ ! -d ${WEBAPPS_DIR} ] ; then \
        echo "\tcreating ${WEBAPPS_DIR}"; \
        mkdir ${WEBAPPS_DIR}; \
    fi
	echo "checking configuration files ..."
	if [ ! -f ${DOCKER_COMPOSE_FILE} ]; then \
		echo "\tgenerating ${DOCKER_COMPOSE_FILE}" ;\
		sed -e 's/user_id/${UID}/g' -e 's/data_directory/${INIT_SCRIPT_DIR}/g' ${DOCKER_COMPOSE_TEMPLATE} > ${DOCKER_COMPOSE_FILE}; \
	fi
$(DATA_ARCHIVES): ##@Setup unpackages the utility archives"
	echo "checking ${DATA_DIRECTORY}" ;\
	if [ ! -d ${DATA_DIRECTORY} ] ; then \
		 echo "creating empty ${DATA_DIRECTORY}" ; \
		 mkdir -p ${DATA_DIRECTORY}; \
	fi
	$(eval VAR1=$(word 1,$(subst ., ,$@)))
	if [ ! -f ${DATA_DIRECTORY}/01_users.sql ]; then \
		echo "extracting archive $@ to ${DATA_DIRECTORY}" ; \
		tar -xzf ${current_dir}/docker/$@ --directory=${DATA_DIRECTORY} ; \
	fi 

up: checkdocker ##@Run Compiles artifatcs, packages app, runs app server and db and deploy application
up: deploy
	@echo "trying to start docker-compose with profile ${PROFILE}"
	docker compose -f ${DOCKER_COMPOSE_FILE} --profile ${PROFILE} up -d

wipe: clean ##@Setup Runs a mvn clean and then removes all generated directoryes and files (including the database data)
	@echo "Wiping up... ${OUTPUT_FILE}"
	if [ -f ${OUTPUT_FILE} ] ; then echo "removing file"; rm ${OUTPUT_FILE}; fi
	if [ -d ${APPS} ] ; then echo "removing ${APPS}"; rm -rf ${APPS}; fi
	if [ -d ${LOGS} ] ; then echo "removing ${LOGS}"; rm -rf ${LOGS}; fi
	if [ -d ${MAVEN_CACHE_DIR} ] ; then echo "removing ${MAVEN_CACHE_DIR}"; rm -rf ${MAVEN_CACHE_DIR}; fi
	if [ -d ${WLSDIR} ] ; then echo "removing ${WLSDIR}"; rm -rf ${WLSDIR}; fi
	if [ -d ${DATA_DIRECTORY} ] ; then echo "removing ${DATA_DIRECTORY}"; rm -rf ${DATA_DIRECTORY}; fi
	if [ -d ${DATABASE} ] ; then echo "removing ${DATABASE}"; rm -rf ${DATABASE}; fi

wipe-ear: ##@Setup Removes the generated ear file and directory
	@echo "Wiping up... ${EAR_TARGET_DIR}"
	if [ -d ${EAR_TARGET_DIR} ] ; then echo "removing ${EAR_TARGET_DIR}"; rm -rf ${EAR_TARGET_DIR}; fi
	@echo "Wiping up... ${APPS}"
	if [ -d ${APPS} ] ; then echo "removing ${APPS}"; rm -rf ${APPS}; fi

update: MVNGOAL="package"  ##@Development Packages application with a production profile. No tests are run
update: MVNFLAG="-DskipTests " 
update: MVNPROFILE="-Pproduction" 
update: mvn
update: deploy

test: MVNGOAL="test" ##@Development Runs junit tests
test: mvn

coverage: MVNGOAL="verify" ##@Documentation Runs junit tests and produces coverage report
coverage: mvn
coverage: 
	if [ -d ${SOURCEBASE}/coverage/target/site/jacoco-aggregate ] ; then\
		echo "copying aggregated results"; \
		rm -rf ${SOURCEBASE}/../coverage; \
		cp -R ${SOURCEBASE}/coverage/target/site/jacoco-aggregate ${SOURCEBASE}/../; \
		mv ${SOURCEBASE}/../jacoco-aggregate ${SOURCEBASE}/../coverage; \
		awk -F"," '{ instructions += $$4 + $$5; covered += $$5 } END { print covered, "/", instructions, "instructions covered"; print 100*covered/instructions, "% covered" }' ${SOURCEBASE}/../coverage/jacoco.csv; \
	fi

compile: MVNGOAL="compile" ##@Development Compiles all the code base
compile: MVNFLAG="-T 4 -Dmaven.test.skip=true" 
compile: MVNPROFILE="" 
compile: mvn

test-compile: MVNGOAL="-T 4 test-compile" ##@Development Compiles the tests without running them
test-compile: MVNFLAG="" 
test-compile: MVNPROFILE="" 
test-compile: mvn

package: MVNGOAL="package" ##@Development Packages application with production profile
package: MVNFLAG="-DskipTests" 
package: MVNPROFILE="-Pproduction" 
package: mvn

clean: MVNGOAL="clean" ##@Development Cleans the compiled code base
clean: MVNPROFILE="" 
clean: MVNFLAG="" 
clean: mvn
clean:
	echo "Undeploy task";\
	if [ -f ${APPS}/muipromo.ear ] ; then \
		echo "\tremoving deployed resources from ${APPS}"; \
		rm ${APPS}/muipromo.ear; \
		rm -rf ${APPS}/muipromo; \
	fi
undeploy: ##@Internal removes deployed resources from ${APPS}: do not run while app is on

deploy: checkdocker ##@Run Deploys the ear artifact into apps directory of container
deploy: generate ${APPS}/muipromo.ear
ifeq ($(PROFILE),create-domain)
	echo "skipping application deployment"
else
ifeq ($(PROFILE),weblogic)
	echo "deploying application ${EAR_TARGET_FILE} to ${WLSDIR}/${DOMAINS_DIR}/${DOMAIN}/autodeploy ..."
	echo "cp ${EAR_TARGET_FILE} ${WLSDIR}/${DOMAINS_DIR}/${DOMAIN}/autodeploy/muipromo.ear ..."
	cp ${EAR_TARGET_FILE} ${WLSDIR}/${DOMAINS_DIR}/${DOMAIN}/autodeploy/muipromo.ear
else
	echo "deploying application ${EAR_TARGET_FILE} to ${APPS} ..."
	echo "cp ${EAR_TARGET_FILE} ${APPS}/muipromo.ear"
	cp ${EAR_TARGET_FILE} ${APPS}/muipromo.ear
endif
endif
## checks if the ear artifact has been created or creates one
${APPS}/muipromo.ear:
ifeq ($(PROFILE),create-domain)
	echo "skipping application package"
else
	if [ -f ${EAR_TARGET_FILE} ]; then \
		echo "no need to recompile "; \
	else \
		echo "missing ${EAR_TARGET_FILE}: repackaging"; \
		$(MAKE) MVNFLAG="-DskipTests" MVNPROFILE="-Pproduction" MVNGOAL="clean package" mvn; \
	fi
endif
mvn: checkdocker##@Miscellaneous maven wrapper recipe
mvn: generate
	echo "flags : $(MVNFLAG)" 
	echo "profile : $(MVNPROFILE)" 
	echo "goal :$(MVNGOAL)"
	$(eval MVNCOMMAND=$(shell echo "$(strip $(MVNFLAG)) $(strip $(MVNPROFILE)) $(strip $(MVNGOAL))" | sed -e "s/ +/ /g"))
	echo "will run the following command: \ndocker run -v ${MAVEN_CACHE_DIR}:/var/maven/.m2 -v ${SRC_DIR}:/var/mui -e MAVEN_CONFIG=/var/maven/.m2 -u ${UID} -ti --rm -w /var/mui maven:${MVN_VERSION} mvn -Duser.home=/var/maven $(MVNCOMMAND)"  ## > mvncommand.txt
	docker run -v ${MAVEN_CACHE_DIR}:/var/maven/.m2 -v ${SRC_DIR}:/var/mui -e MAVEN_CONFIG=/var/maven/.m2 -u ${UID} -ti --rm -w /var/mui maven:${MVN_VERSION} mvn  -Duser.home=/var/maven $(MVNCOMMAND)

checkdocker:
	@which docker > /dev/null || (echo "Could not find docker"; exit 1)
	##@which docker-compose> /dev/null || (echo "Could not find docker-compose"; exit 1)
	@echo "found docker and docker-compose"

mvn_version:
	echo "will run the following command: \ndocker run -v ${MAVEN_CACHE_DIR}:/var/maven/.m2 -v ${SRC_DIR}:/var/mui -e MAVEN_CONFIG=/var/maven/.m2 -u ${UID} -ti --rm -w /var/mui maven:${MVN_VERSION} mvn -Duser.home=/var/maven -q -Dexec.executable="echo" -Dexec.args="'"$${project.version}"'" --non-recursive exec:exec"
	PROJECT_VERSION = $(shell docker run -v ${MAVEN_CACHE_DIR}:/var/maven/.m2 -v ${SRC_DIR}:/var/mui -e MAVEN_CONFIG=/var/maven/.m2 -u ${UID} -ti --rm -w /var/mui maven:${MVN_VERSION} mvn -Duser.home=/var/maven -q -Dexec.executable="echo" -Dexec.args="'"\$$\$${project.version}"'" --non-recursive exec:exec)
	@echo "$(PROJECT_VERSION)"

down: ##@Run stops the application and the running containers
	docker compose -f ${DOCKER_COMPOSE_FILE} --profile ${PROFILE} down --remove-orphans 

build: checkdocker##@Development Build docker images
build:
	echo "Building images"
	docker compose -f ${DOCKER_COMPOSE_FILE} build database tomee
